# Frontend .dockerignore

# ============================
# Secrets & Config
# ============================
.env
.env.*
!.env.example
.env.local
.env.development
.env.production

# ============================
# Build artifacts (sẽ được build lại trong Docker)
# ============================
.next/
out/

# ============================
# Dependencies
# ============================
node_modules/
npm-debug.log*
yarn-debug.log*
.npm/

# ============================
# Git & CI
# ============================
.git/
.gitignore
.gitlab-ci.yml

# ============================
# IDE & OS
# ============================
.vscode/
.idea/
*.DS_Store
Thumbs.db

# ============================
# Documentation
# ============================
*.md
LICENSE
docs/

# ============================
# Testing
# ============================
__tests__/
*.test.js
*.spec.js
coverage/
jest.config.*

# ============================
# Storybook
# ============================
.storybook/
storybook-static/
